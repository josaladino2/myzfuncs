zzhelp () {
	if [ -z ${1} ]; then
		echo "Usage: ${funcstack[1]} all/program"
	else
		if [ -d ${HOMEBREW_PREFIX}/share/zsh/help ]; then
			cd ${HOMEBREW_PREFIX}/share/zsh/help
		else
			cd /usr/share/man/man1
		fi
		case ${1} in
			all) \ls | sed -e 's/.1.*$//' | column
			;;
				*) run-help ${1} || printf "No Help for ${1}
"
			;;
		 esac
	fi
}
