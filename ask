ask () {
	local prompt="${1:-'Continue...'}" 
	local default=${2:-N} 
	local prompt2 default reply
	while true
	do
		if [ "${default}" = "Y" ]
		then
			prompt2="Y/n" 
			default=Y 
		elif [ "${default}" = "N" ]
		then
			prompt2="y/N" 
		else
			prompt2="y/n" 
			default=n 
		fi
		echo -n "${prompt} [$prompt2] "
		vared -p "${prompt} [${prompt2}]:" -c reply
		if [ -z "$reply" ]
		then
			reply=$default 
		fi
		case "$reply" in
			(Y* | y*) return 0 ;;
			(N* | n*) return 1 ;;
		esac
	done
}
